			<string>Today</string>
			<key>UIApplicationShortcutItemIconSymbolName</key>
			<string>pencil.tip.crop.circle</string>
		</dict>
		<dict>
			<key>UIApplicationShortcutItemType</key>
			<string>dev.liyuxuan.joodle.shortcut.nextAnniversary</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Next Anniversary</string>
			<key>UIApplicationShortcutItemIconSymbolName</key>
			<string>calendar.badge.clock</string>
		</dict>
	</array>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIImageName</key>
		<string>LaunchScreen</string>
	</dict>
</dict>
</plist>
