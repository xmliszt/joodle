    "Doodle the keys you used most today (home keys, car keys, or laptop keys).": {
      "comment": "Suggestion to draw the keys you used most today.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc624\ub298 \uac00\uc7a5 \ub9ce\uc774 \uc0ac\uc6a9\ud55c \uc5f4\uc1e0\ub97c \uadf8\ub824\ubcf4\uc138\uc694(\uc9d1 \uc5f4\uc1e0, \ucc28 \uc5f4\uc1e0 \ub610\ub294 \ub178\ud2b8\ubd81 \ud0a4)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u753b\u51fa\u4f60\u4eca\u5929\u7528\u5f97\u6700\u591a\u7684\u94a5\u5319\uff08\u5bb6\u95e8\u94a5\u5319\u3001\u8f66\u94a5\u5319\u6216\u7b14\u8bb0\u672c\u7535\u8111\u6309\u952e\uff09\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Griffonnez les cl\u00e9s que vous avez le plus utilis\u00e9es aujourd'hui (cl\u00e9s de maison, cl\u00e9s de voiture ou cl\u00e9s d'ordinateur portable)."
          }
        }
      }
    },
    "Doodle the pattern of the crumbs or objects on your table at this moment.": {
