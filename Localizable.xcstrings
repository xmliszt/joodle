            "state": "translated",
            "value": "\u4f60\u65e0\u6743\u4f7f\u7528\u6b64\u4ea7\u54c1\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous n'avez pas droit \u00e0 ce produit."
          }
        }
      }
    },
    "You can turn off this prompt in ": {
