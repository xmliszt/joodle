            "value": "\u524d\u5f80 \u8bbe\u7f6e \u2192 [\u4f60\u7684\u540d\u5b57]\uff0c\u786e\u4fdd\u4f60\u5df2\u767b\u5f55 iCloud\u3002"
          }
        },
        "fr": {
          "stringUnit": {
