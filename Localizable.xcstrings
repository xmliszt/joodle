    "%@ per %@. Cancel anytime." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ per %2$@. Cancel anytime."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ par %2$@. Résiliable à tout moment."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ / %2$@。いつでもキャンセルできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%2$@에 %1$@. 언제든지 취소 가능합니다."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%2$@ başına %1$@. İstediğin zaman iptal et."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每%2$@%1$@。可随时取消订阅。"
