            "state": "translated",
            "value": "Impossible de d\u00e9terminer le statut iCloud."
          }
        }
      }
    },
    "Unable to load FAQs. Please check your connection and try again.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "FAQ\ub97c \ubd88\ub7ec\uc62c \uc218 \uc5c6\uc2b5\ub2c8\ub2e4. \uc5f0\uacb0\uc744 \ud655\uc778\ud55c \ub4a4 \ub2e4\uc2dc \uc2dc\ub3c4\ud574 \uc8fc\uc138\uc694."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u65e0\u6cd5\u52a0\u8f7d\u5e38\u89c1\u95ee\u9898\u3002\u8bf7\u68c0\u67e5\u7f51\u7edc\u8fde\u63a5\u540e\u91cd\u8bd5\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de charger la FAQ. Veuillez v\u00e9rifier votre connexion et r\u00e9essayer."
          }
        }
      }
    },
