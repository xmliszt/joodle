    "In \"Settings\", go to \"Labs\" section, then tap on \"Experimental Features\".": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc124\uc815\uc5d0\uc11c \ub7a9 \uc139\uc158\uc73c\ub85c \uc774\ub3d9\ud55c \ub2e4\uc74c \uc2e4\ud5d8\uc801 \uae30\ub2a5\uc744 \ud0ed\ud558\uc138\uc694."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u5728\"\u8bbe\u7f6e\"\u4e2d\uff0c\u8fdb\u5165\"\u5b9e\u9a8c\u5ba4\"\u677f\u5757\uff0c\u7136\u540e\u70b9\u51fb\"\u5b9e\u9a8c\u529f\u80fd\"\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dans \u00ab\u00a0Param\u00e8tres\u00a0\u00bb, allez dans la section \u00ab\u00a0Labs\u00a0\u00bb, puis appuyez sur \u00ab\u00a0Fonctionnalit\u00e9s exp\u00e9rimentales\u00a0\u00bb."
          }
        }
      }
    },
