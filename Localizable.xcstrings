    "Shows an animated water level that drains throughout the day in the background. Water level reacts to the tilting of your device.": {
      "comment": "A description of the \"Passing Time Backdrop\" experimental feature.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ubc30\uacbd\uc5d0\uc11c \ud558\ub8e8 \ub3d9\uc548 \uc810\ucc28 \ub0ae\uc544\uc9c0\ub294 \uc560\ub2c8\uba54\uc774\uc158 \ubb3c \ub192\uc774\ub97c \ubcf4\uc5ec\uc90d\ub2c8\ub2e4. \ubb3c \ub192\uc774\ub294 \uae30\uae30 \uae30\uc6b8\uc784\uc5d0 \ubc18\uc751\ud569\ub2c8\ub2e4."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u5728\u80cc\u666f\u4e2d\u663e\u793a\u5168\u5929\u9010\u6e10\u4e0b\u964d\u7684\u52a8\u6001\u6c34\u4f4d\u3002\u6c34\u4f4d\u4f1a\u968f\u8bbe\u5907\u503e\u659c\u800c\u53d8\u5316\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Affiche un niveau d'eau anim\u00e9 qui s'\u00e9coule tout au long de la journ\u00e9e en arri\u00e8re-plan. Le niveau d'eau r\u00e9agit \u00e0 l'inclinaison de votre appareil."
          }
        }
      }
    },
