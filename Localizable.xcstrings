    "What does the screen of your laptop or tablet look like with its current tabs open?" : {
      "comment" : "A prompt for doodling the current tabs open on a laptop or tablet screen.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "À quoi ressemble l'écran de votre ordinateur portable ou de votre tablette avec ses onglets actuellement ouverts ?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "開いているタブがある状態のノートPCやタブレットの画面は、どんな見た目ですか？"
