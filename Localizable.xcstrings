        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "実験的機能は、私たちが試している小さな楽しいプロジェクトです。これらの機能はパフォーマンスやバッテリー駆動時間に影響する場合があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "실험적 기능은 현재 테스트 중인 작은 실험 프로젝트입니다. 성능이나 배터리 수명에 영향을 줄 수 있습니다."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deneysel özellikler, test ettiğimiz küçük ve eğlenceli projelerdir. Bu özellikler performansı veya pil ömrünü etkileyebilir."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "实验功能是我们正在测试的试用性功能。此类功能可能影响应用性能或电池寿命。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
