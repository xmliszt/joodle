        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u753b\u51fa\u6b64\u523b\u4f60\u684c\u4e0a\u9762\u5305\u5c51\u6216\u7269\u54c1\u7684\u6446\u653e\u56fe\u6848\u3002"
