    "Your data will remain on this device and in iCloud, but will stop syncing with other devices." : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vos données resteront sur cet appareil et dans iCloud, mais ne seront plus synchronisées avec les autres appareils."
          }
