    "iCloud is disabled in iOS Settings. Enable it in \"Settings → [Your Name] → iCloud → Saved to iCloud -> Joodle\" to sync." : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud est désactivé dans les réglages iOS. Activez-le dans « Réglages → [Votre nom] → iCloud → Enregistré sur iCloud → Joodle » pour synchroniser."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud は iOS の設定で無効です。「設定 → [あなたの名前] → iCloud → iCloud に保存 → Joodle」で有効にすると同期できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS 설정에서 iCloud가 비활성화되어 있습니다. 동기화를 위해 \"설정 → [내 이름] → iCloud → iCloud에 저장 → Joodle\"에서 활성화하세요."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud, iOS Ayarları'nda kapalı. Eşitlemek için \"Ayarlar → [Adın] → iCloud → iCloud'a Kaydedildi -> Joodle\" yolundan aç."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS 设置中已停用 iCloud。请在\"设置 → [你的名字] → iCloud → 保存到 iCloud → Joodle\"中启用以进行同步。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud 已在 iOS 設定中停用。請在「設定 → [你的名字] → iCloud → 儲存到 iCloud → Joodle」中啟用以進行同步。"
          }
        }
      }
    },
