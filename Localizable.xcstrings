    "You created your first Joodle!": {
      "comment": "A title that appears in the \"Value Proposition\" screen of the app, welcoming new users to Joodle.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uccab Joodle\uc744 \ub9cc\ub4e4\uc5c8\uc5b4\uc694!"
