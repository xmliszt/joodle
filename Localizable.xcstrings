      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc0c8 \ud14c\ub9c8\uac00 \uc900\ube44\ub418\uc5c8\uc5b4\uc694!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u4f60\u7684\u65b0\u4e3b\u9898\u5df2\u5c31\u7eea\uff01"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre nouveau th\u00e8me est pr\u00eat !"
          }
        }
      }
    },
    "Your subscription will automatically renew on %@. Manage your subscription, change plans, or cancel anytime.": {
      "comment": "A disclaimer explaining that a user's subscription will automatically renew at a specified date. The argument is the formatted expiration date of the subscription.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uad6c\ub3c5\uc740 %@\uc5d0 \uc790\ub3d9 \uac31\uc2e0\ub429\ub2c8\ub2e4. \uad6c\ub3c5\uc744 \uad00\ub9ac\ud558\uace0, \uc694\uae08\uc81c\ub97c \ubcc0\uacbd\ud558\uac70\ub098, \uc5b8\uc81c\ub4e0\uc9c0 \ucde8\uc18c\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u4f60\u7684\u8ba2\u9605\u5c06\u4e8e%@\u81ea\u52a8\u7eed\u8d39\u3002\u7ba1\u7406\u4f60\u7684\u8ba2\u9605\u3001\u66f4\u6539\u65b9\u6848\u6216\u968f\u65f6\u53d6\u6d88\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre abonnement sera automatiquement renouvel\u00e9 le %@. G\u00e9rez votre abonnement, changez de forfait ou annulez \u00e0 tout moment."
          }
        }
      }
    },
    "Your week in doodles": {
      "comment": "Description of a share card style for sharing a week's worth of doodles.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
