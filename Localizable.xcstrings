    "This device is not capable of making payments.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc774 \uae30\uae30\uc5d0\uc11c\ub294 \uacb0\uc81c\ub97c \uc9c4\ud589\ud560 \uc218 \uc5c6\uc2b5\ub2c8\ub2e4."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u6b64\u8bbe\u5907\u4e0d\u652f\u6301\u652f\u4ed8\u529f\u80fd\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cet appareil n'est pas capable d'effectuer des paiements."
          }
        }
      }
    },
    "This product is not available in your region.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc774 \uc0c1\ud488\uc740 \ud604\uc7ac \uc9c0\uc5ed\uc5d0\uc11c \uc774\uc6a9\ud560 \uc218 \uc5c6\uc2b5\ub2c8\ub2e4."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u6b64\u4ea7\u54c1\u5728\u4f60\u6240\u5728\u5730\u533a\u4e0d\u53ef\u7528\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce produit n'est pas disponible dans votre r\u00e9gion."
          }
        }
      }
    },
    "This will restart the full onboarding experience. Today's entry may be overwritten, and you will go through preference setup again.": {
      "comment": "An explanatory message within the confirmation dialog for revisiting the onboarding process.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc804\uccb4 \uc628\ubcf4\ub529\uc744 \ub2e4\uc2dc \uc2dc\uc791\ud569\ub2c8\ub2e4. \uc624\ub298\uc758 \uae30\ub85d\uc774 \ub36e\uc5b4\uc368\uc9c8 \uc218 \uc788\uc73c\uba70, \ud658\uacbd\uc124\uc815\uc744 \ub2e4\uc2dc \uc9c4\ud589\ud558\uac8c \ub429\ub2c8\ub2e4."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u8fd9\u5c06\u91cd\u65b0\u5f00\u59cb\u5b8c\u6574\u7684\u5f15\u5bfc\u4f53\u9a8c\u3002\u4eca\u5929\u7684\u8bb0\u5f55\u53ef\u80fd\u88ab\u8986\u76d6\uff0c\u4f60\u9700\u8981\u91cd\u65b0\u8fdb\u884c\u504f\u597d\u8bbe\u7f6e\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela red\u00e9marrera l\u2019exp\u00e9rience d\u2019int\u00e9gration compl\u00e8te. L'entr\u00e9e d'aujourd'hui peut \u00eatre \u00e9cras\u00e9e et vous devrez \u00e0 nouveau configurer les pr\u00e9f\u00e9rences."
          }
        }
      }
    },
    "This will sync your journal entries and preferences with iCloud, making them available across all your devices.\n\nRequires internet connection and active iCloud account.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc77c\uc9c0 \uae30\ub85d\uacfc \ud658\uacbd\uc124\uc815\uc744 iCloud\uc640 \ub3d9\uae30\ud654\ud558\uc5ec \ubaa8\ub4e0 \uae30\uae30\uc5d0\uc11c \uc0ac\uc6a9\ud560 \uc218 \uc788\uac8c \ud569\ub2c8\ub2e4.\n\n\uc778\ud130\ub137 \uc5f0\uacb0\uacfc \ud65c\uc131\ud654\ub41c iCloud \uacc4\uc815\uc774 \ud544\uc694\ud569\ub2c8\ub2e4."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u8fd9\u5c06\u628a\u4f60\u7684\u65e5\u8bb0\u8bb0\u5f55\u548c\u504f\u597d\u8bbe\u7f6e\u540c\u6b65\u5230 iCloud\uff0c\u4f7f\u5176\u5728\u6240\u6709\u8bbe\u5907\u4e0a\u53ef\u7528\u3002\n\n\u9700\u8981\u4e92\u8054\u7f51\u8fde\u63a5\u548c\u6709\u6548\u7684 iCloud \u8d26\u6237\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela synchronisera vos entr\u00e9es de journal et vos pr\u00e9f\u00e9rences avec iCloud, les rendant ainsi disponibles sur tous vos appareils.\n\nN\u00e9cessite une connexion Internet et un compte iCloud actif."
          }
        }
      }
    },
    "Time to check your Joodle for %@": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@\uc758 Joodle\uc744 \ud655\uc778\ud560 \uc2dc\uac04\uc774\uc5d0\uc694"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u662f\u65f6\u5019\u67e5\u770b\u4f60%@\u7684\u6d82\u9e26\u4e86"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il est temps de v\u00e9rifier votre Joodle pour %@"
          }
        }
      }
    },
    "Time to check your Joodle!": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Joodle\uc744 \ud655\uc778\ud560 \uc2dc\uac04\uc774\uc5d0\uc694!"
          }
        },
        "zh-Hans": {
