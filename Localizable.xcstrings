    "iCloud Sync": {
      "comment": "A setting option that allows users to enable or disable iCloud sync.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud \ub3d9\uae30\ud654"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud \u4e91\u670d\u52a1\u540c\u6b65"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Synchronisation iCloud"
          }
        }
      }
    },
    "iCloud Sync is enabled but requires a restart to start working. Your data will sync after you restart the app.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud \ub3d9\uae30\ud654\uac00 \ud65c\uc131\ud654\ub418\uc5b4 \uc788\uc9c0\ub9cc \uc791\ub3d9\ud558\ub824\uba74 \uc7ac\uc2dc\uc791\uc774 \ud544\uc694\ud569\ub2c8\ub2e4. \uc571\uc744 \ub2e4\uc2dc \uc2dc\uc791\ud558\uba74 \ub370\uc774\ud130 \ub3d9\uae30\ud654\uac00 \uc2dc\uc791\ub429\ub2c8\ub2e4."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud \u4e91\u670d\u52a1\u540c\u6b65\u5df2\u542f\u7528\uff0c\u4f46\u9700\u8981\u91cd\u542f\u624d\u80fd\u751f\u6548\u3002\u91cd\u542f\u5e94\u7528\u540e\u4f60\u7684\u6570\u636e\u5c06\u5f00\u59cb\u540c\u6b65\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud Sync est activ\u00e9 mais n\u00e9cessite un red\u00e9marrage pour commencer \u00e0 fonctionner. Vos donn\u00e9es seront synchronis\u00e9es apr\u00e8s le red\u00e9marrage de l'application."
          }
        }
      }
    },
    "iCloud Unavailable": {
      "comment": "A message indicating that iCloud is currently unavailable.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud\ub97c \uc0ac\uc6a9\ud560 \uc218 \uc5c6\uc74c"
          }
        },
        "zh-Hans": {
          "stringUnit": {
