    "Draw the footwear you just took off, exactly where they landed.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ubc29\uae08 \ubc97\uc5b4\ub193\uc740 \uc2e0\ubc1c\uc744, \uc9c0\uae08 \ub193\uc778 \uadf8\ub300\ub85c\uc758 \uc704\uce58\ub85c \uadf8\ub824\ubcf4\uc138\uc694."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u753b\u51fa\u4f60\u521a\u8131\u4e0b\u7684\u978b\u5b50\uff0c\u5c31\u6309\u5b83\u4eec\u73b0\u5728\u6446\u653e\u7684\u4f4d\u7f6e\u753b\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dessinez les chaussures que vous venez d'enlever, exactement l\u00e0 o\u00f9 elles ont atterri."
          }
        }
      }
    },
    "Draw the shape of the steam or the ripples in your current drink.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc9c0\uae08 \ub9c8\uc2dc\ub294 \uc74c\ub8cc\uc758 \uae40 \ubaa8\uc591\uc774\ub098 \ubb3c\uacb0\uc744 \uadf8\ub824\ubcf4\uc138\uc694."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u753b\u51fa\u4f60\u5f53\u524d\u996e\u54c1\u7684\u84b8\u6c7d\u5f62\u72b6\u6216\u6c34\u9762\u6ce2\u7eb9\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dessinez la forme de la vapeur ou des ondulations de votre boisson actuelle."
          }
        }
      }
    },
    "Draw the specific way your blanket or sleeves are wrinkled right now.": {
      "comment": "A doodling prompt that asks the user to draw the specific way their blanket or sleeves are wrinkled right now.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc9c0\uae08 \ub2f4\uc694\ub098 \uc18c\ub9e4\uc5d0 \uc0dd\uae34 \uc8fc\ub984 \ubaa8\uc591\uc744 \uadf8\ub300\ub85c \uadf8\ub824\ubcf4\uc138\uc694."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u753b\u51fa\u6b64\u523b\u4f60\u7684\u6bef\u5b50\u6216\u8896\u5b50\u7684\u8936\u76b1\u5f62\u6001\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dessinez la mani\u00e8re sp\u00e9cifique dont votre couverture ou vos manches sont froiss\u00e9es en ce moment."
          }
        }
      }
    },
    "Draw the very last thing you ate\u2014just the crumbs or the wrapper.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ubc29\uae08 \ub9c8\uc9c0\ub9c9\uc73c\ub85c \uba39\uc740 \uac83\uc744 \uadf8\ub824\ubcf4\uc138\uc694. \ubd80\uc2a4\ub7ec\uae30\ub098 \ud3ec\uc7a5\uc9c0\ub9cc \uadf8\ub824\ub3c4 \ub429\ub2c8\ub2e4."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u753b\u51fa\u4f60\u521a\u5403\u8fc7\u7684\u6700\u540e\u4e00\u6837\u98df\u7269\u2014\u2014\u53ea\u8981\u753b\u6b8b\u6e23\u6216\u5305\u88c5\u7eb8\u5c31\u884c\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dessinez la toute derni\u00e8re chose que vous avez mang\u00e9e, juste les miettes ou l'emballage."
          }
        }
      }
    },
    "Draw your energy as a literal battery. How many bars are left?": {
      "comment": "A doodling prompt that asks users to draw their energy as a battery, indicating how many bars are left.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc9c0\uae08\uc758 \uc5d0\ub108\uc9c0\ub97c \ubc30\ud130\ub9ac\ub85c \ud45c\ud604\ud574 \ubcf4\uc138\uc694. \ubc30\ud130\ub9ac \uce78\uc774 \uba87 \uce78 \ub0a8\uc558\ub098\uc694?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u628a\u4f60\u7684\u7cbe\u529b\u753b\u6210\u4e00\u5757\u771f\u5b9e\u7684\u7535\u6c60\u3002\u8fd8\u5269\u591a\u5c11\u683c\u7535\uff1f"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Puisez votre \u00e9nergie comme une batterie litt\u00e9rale. Combien de barres reste-t-il ?"
          }
        }
      }
    },
    "Drawing data is stored as individual files in the App Group container (no size limit). Only metadata and thumbnails go into UserDefaults.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uadf8\ub9bc \ub370\uc774\ud130\ub294 App Group \ucee8\ud14c\uc774\ub108\uc5d0 \uac1c\ubcc4 \ud30c\uc77c\ub85c \uc800\uc7a5\ub429\ub2c8\ub2e4(\ud06c\uae30 \uc81c\ud55c \uc5c6\uc74c). \uba54\ud0c0\ub370\uc774\ud130\uc640 \uc378\ub124\uc77c\ub9cc UserDefaults\uc5d0 \uc800\uc7a5\ub429\ub2c8\ub2e4."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u7ed8\u56fe\u6570\u636e\u4ee5\u72ec\u7acb\u6587\u4ef6\u5f62\u5f0f\u5b58\u50a8\u5728\u5e94\u7528\u7ec4\u5bb9\u5668\u4e2d\uff08\u65e0\u5927\u5c0f\u9650\u5236\uff09\u3002\u4ec5\u5143\u6570\u636e\u548c\u7f29\u7565\u56fe\u4f1a\u5b58\u5165 UserDefaults\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les donn\u00e9es de dessin sont stock\u00e9es sous forme de fichiers individuels dans le conteneur App Group (aucune limite de taille). Seules les m\u00e9tadonn\u00e9es et les vignettes vont dans UserDefaults."
          }
        }
      }
    },
