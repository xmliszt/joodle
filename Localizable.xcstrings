    "Draw a candle. How much of it 'burned down' during your workday?": {
      "comment": "A prompt that asks the user to draw a candle and describe how much of it is \"burned down\" during their workday.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ucd08\ub97c \ud558\ub098 \uadf8\ub824\ubcf4\uc138\uc694. \uc624\ub298 \uc5c5\ubb34 \uc2dc\uac04 \ub3d9\uc548 \uc5bc\ub9c8\ub098 \"\ud0c0\ub4e4\uc5b4\uac14\"\ub098\uc694?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u753b\u4e00\u6839\u8721\u70db\u3002\u5b83\u5728\u4f60\u7684\u5de5\u4f5c\u65e5\u4e2d\"\u71c3\u5c3d\"\u4e86\u591a\u5c11\uff1f"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dessine une bougie. Quelle quantit\u00e9 a \u00e9t\u00e9 \u00ab br\u00fbl\u00e9e \u00bb pendant votre journ\u00e9e de travail\u00a0?"
          }
        }
      }
    },
    "Draw a Post-it note with the one word that sums up your afternoon.": {
      "comment": "Suggestion to draw a Post-it note with the one word that sums up the user's afternoon.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc624\ud6c4\ub97c \ud55c \ub2e8\uc5b4\ub85c \uc694\uc57d\ud55c \ud3ec\uc2a4\ud2b8\uc787\uc744 \uadf8\ub824\ubcf4\uc138\uc694."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u753b\u4e00\u5f20\u4fbf\u5229\u8d34\uff0c\u7528\u4e00\u4e2a\u8bcd\u603b\u7ed3\u4f60\u7684\u4e0b\u5348\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dessinez un Post-it avec le mot qui r\u00e9sume votre apr\u00e8s-midi."
          }
        }
      }
    },
    "Draw a simple open door. What is one tiny thing you can see on the other side?": {
      "comment": "A prompt for doodling a simple open door and mentioning one tiny thing visible on the other side.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ub2e8\uc21c\ud55c \uc5f4\ub9b0 \ubb38\uc744 \uadf8\ub824\ubcf4\uc138\uc694. \ubb38 \ub108\uba38\uc5d0 \ubcf4\uc774\ub294 \uc791\uc740 \uac83\uc740 \ubb34\uc5c7\uc778\uac00\uc694?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u753b\u4e00\u6247\u7b80\u5355\u7684\u5f00\u7740\u7684\u95e8\u3002\u4f60\u80fd\u5728\u95e8\u7684\u53e6\u4e00\u8fb9\u770b\u5230\u4ec0\u4e48\u5c0f\u4e1c\u897f\uff1f"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dessinez une simple porte ouverte. Quelle petite chose pouvez-vous voir de l\u2019autre c\u00f4t\u00e9 ?"
          }
        }
      }
    },
    "Draw a simple tea cup. Is it overflowing, half-full, or bone dry?": {
      "comment": "A doodling prompt that asks the user to draw a simple tea cup and describe its fullness.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uac04\ub2e8\ud55c \ucc3b\uc794\uc744 \uadf8\ub824\ubcf4\uc138\uc694. \ub118\uce60 \ub9cc\ud07c \uac00\ub4dd\ud55c\uac00\uc694, \ubc18\ucbe4 \ucc3c\ub098\uc694, \uc544\ub2c8\uba74 \uc644\uc804\ud788 \ube44\uc5c8\ub098\uc694?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u753b\u4e00\u4e2a\u7b80\u5355\u7684\u8336\u676f\u3002\u5b83\u662f\u6ee1\u5230\u6ea2\u51fa\u6765\u3001\u534a\u6ee1\uff0c\u8fd8\u662f\u5b8c\u5168\u7a7a\u7684\uff1f"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dessinez une simple tasse de th\u00e9. Est-il d\u00e9bordant, \u00e0 moiti\u00e9 plein ou compl\u00e8tement sec\u00a0?"
          }
        }
      }
    },
    "Draw a small backpack. Draw one heavy rock inside for your biggest worry.": {
      "comment": "A prompt for doodling a small backpack with a heavy rock inside, symbolizing a worry.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc791\uc740 \ubc30\ub0ad\uc744 \uadf8\ub9ac\uace0, \uac00\uc7a5 \ud070 \uac71\uc815\uc744 \ub098\ud0c0\ub0b4\ub294 \ubb34\uac70\uc6b4 \ub3cc \ud558\ub098\ub97c \uc548\uc5d0 \uadf8\ub824\ubcf4\uc138\uc694."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u753b\u4e00\u4e2a\u5c0f\u80cc\u5305\u3002\u5728\u91cc\u9762\u753b\u4e00\u5757\u6c89\u91cd\u7684\u77f3\u5934\uff0c\u4ee3\u8868\u4f60\u6700\u5927\u7684\u70e6\u607c\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dessinez un petit sac \u00e0 dos. Dessinez une grosse pierre \u00e0 l\u2019int\u00e9rieur pour votre plus gros souci."
          }
        }
      }
    },
    "Draw a tiny trophy for one thing you actually finished today.": {
      "comment": "Suggestion to draw a tiny trophy for one thing they actually finished today.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc624\ub298 \uc2e4\uc81c\ub85c \ub05d\ub0b8 \ud55c \uac00\uc9c0\ub97c \uc704\ud574 \uc791\uc740 \ud2b8\ub85c\ud53c\ub97c \uadf8\ub824\ubcf4\uc138\uc694."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u4e3a\u4f60\u4eca\u5929\u771f\u6b63\u5b8c\u6210\u7684\u4e00\u4ef6\u4e8b\u753b\u4e00\u4e2a\u5c0f\u5c0f\u7684\u5956\u676f\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dessinez un petit troph\u00e9e pour une chose que vous avez r\u00e9ellement termin\u00e9e aujourd'hui."
          }
        }
      }
    },
    "Draw and Edit Joodle": {
      "comment": "Title of a tutorial step that involves drawing and editing a joodle.",
