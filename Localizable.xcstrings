    "You already own Joodle forever. There is no need to purchase subscription plans.": {
      "comment": "A disclaimer text that appears when the user already has a lifetime subscription to Joodle.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc774\ubbf8 Joodle\uc744 \uc601\uad6c \uc18c\uc720\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uad6c\ub3c5 \uc694\uae08\uc81c\ub97c \uad6c\ub9e4\ud560 \ud544\uc694\uac00 \uc5c6\uc2b5\ub2c8\ub2e4."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u4f60\u5df2\u6c38\u4e45\u62e5\u6709 Joodle\uff0c\u65e0\u9700\u8d2d\u4e70\u8ba2\u9605\u65b9\u6848\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous poss\u00e9dez d\u00e9j\u00e0 Joodle depuis toujours. Il n'est pas n\u00e9cessaire d'acheter des plans d'abonnement."
          }
        }
      }
    },
    "You are currently simulating production environment. Tap to return to development mode.": {
      "comment": "A message displayed in the footer of the \"Developer Options\" section in the settings view, explaining that users can exit the simulated production environment by tapping a button.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ud604\uc7ac \ud504\ub85c\ub355\uc158 \ud658\uacbd\uc744 \uc2dc\ubbac\ub808\uc774\uc158 \uc911\uc785\ub2c8\ub2e4. \ud0ed\ud558\uc5ec \uac1c\ubc1c \ubaa8\ub4dc\ub85c \ub3cc\uc544\uac00\uc138\uc694."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u4f60\u5f53\u524d\u6b63\u5728\u6a21\u62df\u751f\u4ea7\u73af\u5883\u3002\u70b9\u51fb\u8fd4\u56de\u5f00\u53d1\u6a21\u5f0f\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous simulez actuellement un environnement de production. Appuyez pour revenir au mode d\u00e9veloppement."
          }
        }
      }
    },
    "You are not entitled to this product.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc774 \uc0c1\ud488\uc744 \uc0ac\uc6a9\ud560 \uad8c\ud55c\uc774 \uc5c6\uc2b5\ub2c8\ub2e4."
