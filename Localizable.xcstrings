    "Experimental features are fun little projects that we are testing. These features may affect performance or battery life.": {
      "comment": "A description of experimental features, highlighting their potential impact on performance or battery life.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc2e4\ud5d8\uc801 \uae30\ub2a5\uc740 \ud604\uc7ac \ud14c\uc2a4\ud2b8 \uc911\uc778 \uc791\uc740 \uc2e4\ud5d8 \ud504\ub85c\uc81d\ud2b8\uc785\ub2c8\ub2e4. \uc131\ub2a5\uc774\ub098 \ubc30\ud130\ub9ac \uc218\uba85\uc5d0 \uc601\ud5a5\uc744 \uc904 \uc218 \uc788\uc2b5\ub2c8\ub2e4."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u5b9e\u9a8c\u529f\u80fd\u662f\u6211\u4eec\u6b63\u5728\u6d4b\u8bd5\u7684\u8bd5\u7528\u6027\u529f\u80fd\u3002\u6b64\u7c7b\u529f\u80fd\u53ef\u80fd\u5f71\u54cd\u5e94\u7528\u6027\u80fd\u6216\u7535\u6c60\u5bff\u547d\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les fonctionnalit\u00e9s exp\u00e9rimentales sont des petits projets amusants que nous testons. Ces fonctionnalit\u00e9s peuvent affecter les performances ou la dur\u00e9e de vie de la batterie."
          }
        }
      }
    },
