    "Tap to set an anniversary alarm. Anniversary alarm can only be set if it is today or in the future.": {
      "comment": "Tooltip message for adding an anniversary reminder.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ud0ed\ud558\uc5ec \uae30\ub150\uc77c \uc54c\ub9bc\uc744 \uc124\uc815\ud558\uc138\uc694. \uae30\ub150\uc77c \uc54c\ub9bc\uc740 \uc624\ub298 \ub610\ub294 \ubbf8\ub798 \ub0a0\uc9dc\uc5d0\ub9cc \uc124\uc815\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u70b9\u51fb\u8bbe\u7f6e\u7eaa\u5ff5\u65e5\u95f9\u949f\u3002\u4ec5\u53ef\u8bbe\u7f6e\u4eca\u65e5\u6216\u672a\u6765\u65e5\u671f\u7684\u7eaa\u5ff5\u65e5\u95f9\u949f\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez pour d\u00e9finir une alarme d'anniversaire. L'alarme d'anniversaire ne peut \u00eatre r\u00e9gl\u00e9e que si c'est aujourd'hui ou dans le futur."
          }
        }
      }
    },
