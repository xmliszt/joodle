    "Try disabling iCloud sync, waiting 10 seconds, then re-enabling it. This recreates the sync connection.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud \ub3d9\uae30\ud654\ub97c \ub044\uace0 10\ucd08 \uae30\ub2e4\ub9b0 \ub4a4 \ub2e4\uc2dc \ucf1c \ubcf4\uc138\uc694. \ub3d9\uae30\ud654 \uc5f0\uacb0\uc744 \ub2e4\uc2dc \uc0dd\uc131\ud569\ub2c8\ub2e4."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u5c1d\u8bd5\u7981\u7528 iCloud \u540c\u6b65\uff0c\u7b49\u5f85 10 \u79d2\u540e\u91cd\u65b0\u542f\u7528\u3002\u8fd9\u5c06\u91cd\u5efa\u540c\u6b65\u8fde\u63a5\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Essayez de d\u00e9sactiver la synchronisation iCloud, attendez 10 secondes, puis r\u00e9activez-la. Cela recr\u00e9e la connexion de synchronisation."
          }
        }
      }
    },
