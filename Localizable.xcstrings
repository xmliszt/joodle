        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u89e6\u89c9\u53cd\u9988\u8fd8\u53d6\u51b3\u4e8e\u8bbe\u5907\u7684\u632f\u52a8\u8bbe\u7f6e\uff08\u8bbe\u7f6e > \u8f85\u52a9\u529f\u80fd > \u89e6\u63a7 > \u632f\u52a8\uff09\u3002"
