    "One-time payment of %@. No subscription, no recurring charges. Unlock all features forever.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ \uc77c\ud68c\uc131 \uacb0\uc81c. \uad6c\ub3c5\uc774\ub098 \ubc18\ubcf5 \uacb0\uc81c \uc5c6\uc774 \ubaa8\ub4e0 \uae30\ub2a5\uc744 \uc601\uad6c \uc7a0\uae08 \ud574\uc81c\ud569\ub2c8\ub2e4."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u4e00\u6b21\u6027\u652f\u4ed8%@\u3002\u65e0\u9700\u8ba2\u9605\uff0c\u65e0\u91cd\u590d\u6536\u8d39\u3002\u6c38\u4e45\u89e3\u9501\u6240\u6709\u529f\u80fd\u3002\n"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Paiement unique de %@. Pas d'abonnement, pas de frais r\u00e9currents. D\u00e9bloquez toutes les fonctionnalit\u00e9s pour toujours."
          }
        }
      }
    },
