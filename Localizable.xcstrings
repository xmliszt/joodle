        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@\n\nこの問題が解決しない場合は、開発者にお問い合わせください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@\n\n이 문제가 계속되면 개발자에게 문의해 주세요."
