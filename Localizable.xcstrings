        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u5728\u7cfb\u7edf\u8bbe\u7f6e\u4e2d\u7ba1\u7406\u7167\u7247\u6743\u9650\u3001Siri \u4e0e\u641c\u7d22\u4ee5\u53ca\u901a\u77e5\u5916\u89c2\u3002"
          }
        },
        "fr": {
