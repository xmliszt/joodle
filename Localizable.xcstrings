    "Experimental features are fun little projects that we are testing. These features may affect performance or battery life." : {
      "comment" : "A description of experimental features, highlighting their potential impact on performance or battery life.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "fr" : {
          "stringUnit" : {
