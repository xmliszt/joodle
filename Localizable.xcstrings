    },
    "Please enable notifications in Settings to receive daily reminders.": {
      "comment": "An alert message that appears when a user tries to enable daily reminders but hasn't granted notification permissions yet. The message instructs the user to open the Settings app to grant permissions.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ub9e4\uc77c \uc54c\ub9bc\uc744 \ubc1b\uc73c\ub824\uba74 \uc124\uc815\uc5d0\uc11c \uc54c\ub9bc\uc744 \ud65c\uc131\ud654\ud574 \uc8fc\uc138\uc694."
          }
        },
        "zh-Hans": {
