        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ud56d\ubaa9\ub2f9: %1$@ \uadf8\ub9bc \ub370\uc774\ud130. %3$lld\uac1c \ud56d\ubaa9\uc758 \uc704\uc82f \ud398\uc774\ub85c\ub4dc \ucd1d \uc608\uc0c1: \uc57d %2$@."
          }
