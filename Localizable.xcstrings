      }
    },
    "iCloud is disabled in Settings. Enable it in 'Settings \u2192 [Your Name] \u2192 iCloud \u2192 Saved to iCloud \u2192 Joodle'.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc124\uc815\uc5d0\uc11c iCloud\uac00 \ube44\ud65c\uc131\ud654\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4. '\uc124\uc815 \u2192 [\ub0b4 \uc774\ub984] \u2192 iCloud \u2192 iCloud\uc5d0 \uc800\uc7a5 \u2192 Joodle'\uc5d0\uc11c \ud65c\uc131\ud654\ud558\uc138\uc694."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u8bbe\u7f6e\u4e2d\u5df2\u505c\u7528 iCloud\u3002\u8bf7\u5728\"\u8bbe\u7f6e \u2192 [\u4f60\u7684\u540d\u5b57] \u2192 iCloud \u2192 \u4fdd\u5b58\u5230 iCloud \u2192 Joodle\"\u4e2d\u542f\u7528\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud est d\u00e9sactiv\u00e9 dans Param\u00e8tres. Activez-le dans \u00ab Param\u00e8tres \u2192 [Votre nom] \u2192 iCloud \u2192 Enregistr\u00e9 sur iCloud \u2192 Joodle \u00bb."
          }
        }
      }
    },
