        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u6bcf\u6761\u8bb0\u5f55\uff1a%@ \u7ed8\u56fe\u6570\u636e\u3002\u9884\u4f30\u603b\u8ba1\uff1a% lld \u6761\u8bb0\u5f55\u5bf9\u5e94\u7684\u5c0f\u7ec4\u4ef6\u6570\u636e\u8d1f\u8f7d\u7ea6\u4e3a %@\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chaque entr\u00e9e\u00a0: %1$@ donn\u00e9es de dessin. Estimation totale\u00a0: ~%2$@ charge utile du widget pour %3$lld entr\u00e9es."
