    "Look up. What is the shape of the cloud or the patch of sky you see?" : {
      "comment" : "A doodling prompt that encourages the user to draw the shape of a cloud or sky patch they see in the sky.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
