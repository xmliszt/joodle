    "Look at your dominant hand. Draw the shape it makes resting on your lap." : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regardez votre main dominante. Dessinez la forme qu'elle prend posée sur vos genoux."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "利き手を見て、膝の上で作る形を描いてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "주로 쓰는 손을 보세요. 무릎 위에 올려둔 모양을 그려보세요."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Baskın eline bak. Kucağında dururken oluşturduğu şekli çiz."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "看看你常用的那只手。画出它放在你腿上的形状。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "看看你慣用的那隻手。畫出它放在你腿上的形狀。"
          }
        }
      }
    },
    "Look up. What is the shape of the cloud or the patch of sky you see?" : {
      "comment" : "A doodling prompt that encourages the user to draw the shape of a cloud or sky patch they see in the sky.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Levez les yeux. Quelle forme a le nuage ou le morceau de ciel que vous voyez ?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "見上げて、見えている雲や空のかたまりの形を描いてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "고개를 들어보세요. 보이는 구름이나 하늘 조각은 어떤 모양인가요?"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yukarı bak. Gördüğün bulutun ya da gökyüzü parçasının şekli nasıl?"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "抬头看。你看到的云朵或者天空是什么形状？"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "抬頭看。你看到的雲朵或那片天空是什麼形狀？"
          }
        }
      }
    },
    "Made with Joodle" : {
      "comment" : "A text label displayed as a watermark at the bottom-right corner of the screen, indicating that the app was developed using Joodle.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
