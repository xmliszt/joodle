      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc9c0\uae08 \ucc45\uc0c1 \uc704\uc758 \ubd80\uc2a4\ub7ec\uae30\ub098 \ubb3c\uac74 \ubc30\uce58 \ud328\ud134\uc744 \ub099\uc11c\ud574 \ubcf4\uc138\uc694."
