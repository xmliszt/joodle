    "App-only changes don't affect StoreKit. Use 'Sync from StoreKit' to restore actual status.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc571\uc5d0\uc11c\ub9cc \ubc14\uafbc \ub0b4\uc6a9\uc740 StoreKit\uc5d0 \uc601\ud5a5\uc744 \uc8fc\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4. \uc2e4\uc81c \uc0c1\ud0dc\ub97c \ubcf5\uc6d0\ud558\ub824\uba74 'StoreKit\uc5d0\uc11c \ub3d9\uae30\ud654'\ub97c \uc0ac\uc6a9\ud558\uc138\uc694."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u4ec5\u5e94\u7528\u5185\u4fee\u6539\u4e0d\u4f1a\u5f71\u54cd\u5546\u5e97\u5de5\u5177\u5305\uff08StoreKit\uff09\u3002\u8bf7\u4f7f\u7528 \"\u4ece\u5546\u5e97\u5de5\u5177\u5305\u540c\u6b65\" \u6062\u590d\u5b9e\u9645\u72b6\u6001\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les modifications apport\u00e9es aux applications uniquement n\u2019affectent pas StoreKit. Utilisez \u00ab\u00a0Sync depuis StoreKit\u00a0\u00bb pour restaurer l'\u00e9tat actuel."
          }
        }
      }
    },
