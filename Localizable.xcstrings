    "%@\n\nIf this issue persists, please contact the developer." : {
      "comment" : "An alert message that appears when a purchase attempt fails. The message includes the error description passed as a parameter.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@\n\nSi ce problème persiste, veuillez contacter le développeur."
