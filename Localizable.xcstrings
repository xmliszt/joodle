    "Create a local backup of your Joodle entries or restore from a previous backup. Backups are saved as JSON files.": {
      "comment": "A footer text in the \"Backup & Restore Settings\" view, providing instructions on how to back up or restore data.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Joodle \uae30\ub85d\uc758 \ub85c\uceec \ubc31\uc5c5\uc744 \ub9cc\ub4e4\uac70\ub098 \uc774\uc804 \ubc31\uc5c5\uc5d0\uc11c \ubcf5\uc6d0\ud558\uc138\uc694. \ubc31\uc5c5\uc740 JSON \ud30c\uc77c\ub85c \uc800\uc7a5\ub429\ub2c8\ub2e4."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u4e3a\u4f60\u7684 Joodle \u6d82\u9e26\u6570\u636e\u521b\u5efa\u672c\u5730\u5907\u4efd\uff0c\u6216\u4ece\u5386\u53f2\u5907\u4efd\u6062\u590d\u3002\u5907\u4efd\u6587\u4ef6\u683c\u5f0f\u4e3a JSON\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cr\u00e9ez une sauvegarde locale de vos entr\u00e9es Joodle ou restaurez \u00e0 partir d'une sauvegarde pr\u00e9c\u00e9dente. Les sauvegardes sont enregistr\u00e9es sous forme de fichiers JSON."
          }
        }
      }
    },
