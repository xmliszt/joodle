          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez atteint votre limite Joodle gratuite"
          }
        }
      }
    },
    "Your Current Plan": {
      "comment": "A label displayed above the user's current subscription plan.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ud604\uc7ac \uc694\uae08\uc81c"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u4f60\u7684\u5f53\u524d\u8ba2\u9605"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre forfait actuel"
          }
        }
      }
    },
    "Your data will remain on this device and in iCloud, but will stop syncing with other devices.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ub370\uc774\ud130\ub294 \uc774 \uae30\uae30\uc640 iCloud\uc5d0 \ub0a8\uc544 \uc788\uc9c0\ub9cc, \ub2e4\ub978 \uae30\uae30\uc640\uc758 \ub3d9\uae30\ud654\ub294 \uc911\uc9c0\ub429\ub2c8\ub2e4."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u4f60\u7684\u6570\u636e\u5c06\u4fdd\u7559\u5728\u6b64\u8bbe\u5907\u548c  iCloud\u4e91\u670d\u52a1\u4e2d\uff0c\u4f46\u5c06\u505c\u6b62\u4e0e\u5176\u4ed6\u8bbe\u5907\u540c\u6b65\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vos donn\u00e9es resteront sur cet appareil et dans iCloud, mais cesseront de se synchroniser avec d'autres appareils."
          }
        }
      }
    },
    "Your Joodle Pro subscription has ended. Some features are now limited.": {
      "comment": "An alert message explaining that the user's Joodle Pro subscription has ended, limiting some features.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Joodle Pro \uad6c\ub3c5\uc774 \uc885\ub8cc\ub418\uc5c8\uc2b5\ub2c8\ub2e4. \uc77c\ubd80 \uae30\ub2a5\uc774 \uc774\uc81c \uc81c\ud55c\ub429\ub2c8\ub2e4."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u4f60\u7684 Joodle Pro \u8ba2\u9605\u5df2\u7ed3\u675f\u3002\u90e8\u5206\u529f\u80fd\u73b0\u5df2\u53d7\u9650\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre abonnement Joodle Pro est termin\u00e9. Certaines fonctionnalit\u00e9s sont d\u00e9sormais limit\u00e9es."
          }
        }
      }
    },
    "Your memories are still here, quietly waiting for you. Rediscover the Joodles you once created, each carrying a piece of your story.": {
      "comment": "A paragraph describing the benefits of having active subscriptions for users who have already subscribed.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ub2f9\uc2e0\uc758 \uae30\uc5b5\uc740 \uc5ec\uc804\ud788 \uc774\uacf3\uc5d0\uc11c \uc870\uc6a9\ud788 \uae30\ub2e4\ub9ac\uace0 \uc788\uc5b4\uc694. \ud55c\ub54c \ub9cc\ub4e4\uc5c8\ub358 Joodle\uc744 \ub2e4\uc2dc \ub9cc\ub098 \ubcf4\uc138\uc694. \uac01\uac01\uc774 \ub2f9\uc2e0 \uc774\uc57c\uae30\uc758 \ud55c \uc870\uac01\uc744 \ub2f4\uace0 \uc788\uc2b5\ub2c8\ub2e4."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u4f60\u7684\u8bb0\u5fc6\u4ecd\u5728\u8fd9\u91cc\uff0c\u9759\u9759\u7b49\u5f85\u7740\u4f60\u3002\u91cd\u65b0\u53d1\u73b0\u4f60\u66fe\u7ecf\u521b\u5efa\u7684\u6d82\u9e26\uff0c\u6bcf\u4e00\u4e2a\u90fd\u627f\u8f7d\u7740\u4f60\u6545\u4e8b\u7684\u4e00\u90e8\u5206\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vos souvenirs sont toujours l\u00e0, vous attendant tranquillement. Red\u00e9couvrez les Joodles que vous avez cr\u00e9\u00e9s, chacun portant un morceau de votre histoire."
          }
        }
      }
    },
    "Your month in doodles": {
      "comment": "Description of a share card style when the user is viewing their month in doodles.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc774\ub2ec\uc758 Joodle"
          }
        },
        "zh-Hans": {
          "stringUnit": {
