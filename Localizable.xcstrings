      }
    },
    "You have free access to all Pro features for %@ more.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc55e\uc73c\ub85c %@ \ub3d9\uc548 \ubaa8\ub4e0 Pro \uae30\ub2a5\uc744 \ubb34\ub8cc\ub85c \uc774\uc6a9\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u4f60\u8fd8\u53ef\u4ee5\u514d\u8d39\u4f7f\u7528\u6240\u6709 Pro \u529f\u80fd%@\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez un acc\u00e8s gratuit \u00e0 toutes les fonctionnalit\u00e9s Pro pour %@ plus."
          }
        }
      }
    },
    "You have full access to all features. Thank you for your support!": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ubaa8\ub4e0 \uae30\ub2a5\uc5d0 \ub300\ud55c \uc804\uccb4 \uc561\uc138\uc2a4 \uad8c\ud55c\uc774 \uc788\uc2b5\ub2c8\ub2e4. \uc9c0\uc6d0\ud574 \uc8fc\uc154\uc11c \uac10\uc0ac\ud569\ub2c8\ub2e4!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u4f60\u5df2\u62e5\u6709\u6240\u6709\u529f\u80fd\u7684\u5b8c\u6574\u4f7f\u7528\u6743\u9650\u3002\u611f\u8c22\u4f60\u7684\u652f\u6301\uff01"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez un acc\u00e8s complet \u00e0 toutes les fonctionnalit\u00e9s. Merci pour votre soutien !"
          }
        }
      }
    },
    "You own Joodle Pro forever. Thank you for your support!": {
      "comment": "A message displayed when a user has a lifetime Joodle Pro subscription.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Joodle Pro\ub97c \uc601\uad6c \uc18c\uc720\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc9c0\uc6d0\ud574 \uc8fc\uc154\uc11c \uac10\uc0ac\ud569\ub2c8\ub2e4!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u4f60\u6c38\u4e45\u62e5\u6709 Joodle Pro\u3002\u611f\u8c22\u4f60\u7684\u652f\u6301\uff01"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous poss\u00e9dez Joodle Pro pour toujours. Merci pour votre soutien !"
          }
        }
      }
    },
    "You'll continue to have access to Joodle Pro until %@. After that, you'll lose access to all premium features. Re-subscribe to continue enjoying Joodle Pro after your current period ends.": {
      "comment": "A disclaimer explaining that a user will continue to have access to premium features after their current subscription period ends, but they will no longer be able to upgrade to a premium plan.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@\uae4c\uc9c0 Joodle Pro\ub97c \uacc4\uc18d \uc774\uc6a9\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc774\ud6c4\uc5d0\ub294 \ubaa8\ub4e0 \ud504\ub9ac\ubbf8\uc5c4 \uae30\ub2a5\uc5d0 \uc811\uadfc\ud560 \uc218 \uc5c6\uc2b5\ub2c8\ub2e4. \ud604\uc7ac \uae30\uac04\uc774 \ub05d\ub09c \ub4a4\uc5d0\ub3c4 Joodle Pro\ub97c \uacc4\uc18d \uc774\uc6a9\ud558\ub824\uba74 \ub2e4\uc2dc \uad6c\ub3c5\ud558\uc138\uc694."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u4f60\u5c06\u7ee7\u7eed\u4f7f\u7528 Joodle Pro \u76f4\u5230%@\u3002\u4e4b\u540e\u4f60\u5c06\u5931\u53bb\u6240\u6709\u9ad8\u7ea7\u529f\u80fd\u3002\u5728\u5f53\u524d\u5468\u671f\u7ed3\u675f\u540e\u91cd\u65b0\u8ba2\u9605\u4ee5\u7ee7\u7eed\u4f7f\u7528 Joodle Pro\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous continuerez \u00e0 avoir acc\u00e8s \u00e0 Joodle Pro jusqu'au %@. Apr\u00e8s cela, vous perdrez l\u2019acc\u00e8s \u00e0 toutes les fonctionnalit\u00e9s premium. R\u00e9abonnez-vous pour continuer \u00e0 profiter de Joodle Pro apr\u00e8s la fin de votre p\u00e9riode en cours."
          }
        }
      }
    },
    "You're all set!": {
      "comment": "A title displayed in the onboarding completion view.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc900\ube44 \uc644\ub8cc!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u4e00\u5207\u5c31\u7eea\uff01"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous \u00eates pr\u00eat\u00a0!"
          }
        }
      }
    },
    "You're ready to start Joodling": {
      "comment": "A message displayed below the \"Tutorial Complete!\" text, indicating that the user is ready to start using Joodling.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Joodling\uc744 \uc2dc\uc791\ud560 \uc900\ube44\uac00 \ub418\uc5c8\uc5b4\uc694"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u4f60\u5df2\u51c6\u5907\u597d\u5f00\u59cb\u6d82\u9e26\u4e4b\u65c5"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous \u00eates pr\u00eat \u00e0 commencer \u00e0 Joodler"
          }
        }
      }
    },
    "You've reached your free Joodle limit": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ubb34\ub8cc Joodle \ud55c\ub3c4\uc5d0 \ub3c4\ub2ec\ud588\uc2b5\ub2c8\ub2e4"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
