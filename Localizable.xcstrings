        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u4f60\u521b\u5efa\u4e86\u4f60\u7684\u7b2c\u4e00\u4e2a\u6d82\u9e26\uff01"
          }
