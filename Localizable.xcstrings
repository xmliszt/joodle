    "Free account can only edit the first %lld Joodles. This Joodle is #%lld.": {
      "comment": "Error message shown when a user tries to edit a Joodle that is locked because they are on a free account and have already reached the free Joodle limit. The argument is the 1-based index of the Joodle that is locked.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Free account can only edit the first %1$lld Joodles. This Joodle is #%2$lld."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ubb34\ub8cc \uacc4\uc815\uc740 \ucc98\uc74c %1$lld\uac1c\uc758 Joodle\ub9cc \ud3b8\uc9d1\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc774 Joodle\uc740 #%2$lld\uc785\ub2c8\ub2e4."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u514d\u8d39\u7528\u6237\u53ea\u80fd\u7f16\u8f91\u524d%1$lld\u4e2a\u6d82\u9e26\u65e5\u8bb0\u3002\u8fd9\u4e2a\u6d82\u9e26\u65e5\u8bb0\u662f\u7b2c%2$lld\u4e2a\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le compte gratuit ne peut modifier que les premiers %1$lld Joodles. Ce Joodle est #%2$lld."
