    "The selected time has already passed. Please choose a future time for your anniversary alarm.": {
      "comment": "An alert message that appears when the user tries to set an anniversary alarm for a time that has already passed.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc120\ud0dd\ud55c \uc2dc\uac04\uc774 \uc774\ubbf8 \uc9c0\ub0ac\uc2b5\ub2c8\ub2e4. \uae30\ub150\uc77c \uc54c\ub9bc\uc740 \ubbf8\ub798 \uc2dc\uac04\uc73c\ub85c \uc120\ud0dd\ud574 \uc8fc\uc138\uc694."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u6240\u9009\u65f6\u95f4\u5df2\u8fc7\u3002\u8bf7\u4e3a\u7eaa\u5ff5\u65e5\u95f9\u949f\u9009\u62e9\u4e00\u4e2a\u672a\u6765\u7684\u65f6\u95f4\u3002"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'heure s\u00e9lectionn\u00e9e est d\u00e9j\u00e0 pass\u00e9e. Veuillez choisir une heure ult\u00e9rieure pour votre alarme d'anniversaire."
          }
        }
      }
    },
