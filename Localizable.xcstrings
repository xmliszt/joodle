    },
    "Joodle needs camera access to capture reference photos for tracing. Enable it in Settings." : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Joodle a besoin d'accéder à l'appareil photo pour capturer des photos de référence à décalquer. Activez-le dans les Réglages."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Joodle はトレース用の参考写真を撮影するためにカメラへのアクセスが必要です。設定で有効にしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Joodle에서 따라 그리기용 참고 사진을 촬영하려면 카메라 접근 권한이 필요합니다. 설정에서 활성화해 주세요."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Joodle'ın, üzerinden çizim yapman için referans fotoğrafları çekmek üzere kamera erişimine ihtiyacı var. Ayarlar'dan aç."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Joodle 需要访问相机以拍摄用于描摹的参考照片。请在“设置”中开启。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Joodle 需要存取相機，以拍攝用於描摹的參考照片。請在「設定」中開啟。"
          }
        }
      }
    },
    "Joodle needs permission to add photos to your library. Enable Photos access in Settings to save captured reference photos." : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Joodle a besoin d'une autorisation pour ajouter des photos à votre photothèque. Activez l'accès aux photos dans les Réglages pour enregistrer les photos de référence capturées."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Joodle が写真をライブラリに追加するには許可が必要です。撮影した参考写真を保存するには、設定で写真へのアクセスを有効にしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Joodle에서 사진을 보관함에 추가하려면 권한이 필요합니다. 촬영한 참고 사진을 저장하려면 설정에서 사진 접근 권한을 활성화해 주세요."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Joodle'ın, fotoğrafları kitaplığına ekleyebilmesi için izne ihtiyacı var. Çektiğin referans fotoğrafları kaydetmek için Ayarlar'dan Fotoğraflar erişimini aç."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Joodle 需要权限才能将照片添加到你的照片图库。请在“设置”中开启照片访问权限，以保存拍摄的参考照片。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Joodle 需要權限才能將照片加入你的照片圖庫。請在「設定」中開啟照片取用權限，以儲存拍攝的參考照片。"
          }
        }
      }
    },
